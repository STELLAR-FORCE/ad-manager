generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// 広告媒体: google / yahoo / bing
// 広告種別: search（リスティング）/ display（ディスプレイ）

model Campaign {
  id            String   @id @default(cuid())
  name          String
  platform      String   // "google" | "yahoo" | "bing"
  adType        String   // "search" | "display"
  status        String   @default("active") // "active" | "paused" | "ended"
  monthlyBudget Float?   // 月次予算（円）
  createdAt     DateTime @default(now())

  adGroups   AdGroup[]
  budgetLogs BudgetLog[]
  metrics    DailyMetric[]
  searchTerms SearchTermReport[]
}

model AdGroup {
  id         String @id @default(cuid())
  campaignId String
  name       String
  status     String @default("active")

  campaign  Campaign    @relation(fields: [campaignId], references: [id])
  creatives Creative[]
}

// クリエイティブ（広告）
model Creative {
  id           String  @id @default(cuid())
  adGroupId    String
  name         String
  type         String  // "text" | "image" | "responsive"
  headline1    String?
  headline2    String?
  headline3    String?
  description1 String?
  description2 String?
  status       String  @default("active") // "active" | "paused" | "removed"

  adGroup   AdGroup          @relation(fields: [adGroupId], references: [id])
  histories CreativeHistory[]
}

// クリエイティブの変更履歴
model CreativeHistory {
  id         String   @id @default(cuid())
  creativeId String
  changedBy  String
  changeType String   // "created" | "updated" | "paused" | "resumed" | "removed"
  beforeData String?
  afterData  String?
  note       String?
  changedAt  DateTime @default(now())

  creative Creative @relation(fields: [creativeId], references: [id])
}

// 日次パフォーマンスデータ
model DailyMetric {
  id          String   @id @default(cuid())
  date        DateTime
  campaignId  String
  platform    String   // "google" | "yahoo" | "bing"

  impressions Int   @default(0)
  clicks      Int   @default(0)
  cost        Float @default(0)
  conversions Int   @default(0)

  ctr Float @default(0)
  cpc Float @default(0)
  cpa Float @default(0)

  campaign Campaign @relation(fields: [campaignId], references: [id])

  @@unique([date, campaignId, platform])
}

// 予算ログ
model BudgetLog {
  id         String @id @default(cuid())
  campaignId String
  month      String // "2025-03" 形式
  budget     Float
  spent      Float  @default(0)

  campaign Campaign @relation(fields: [campaignId], references: [id])
}

// 検索語句レポート（除外キーワード分析用）
model SearchTermReport {
  id           String   @id @default(cuid())
  date         DateTime
  platform     String
  campaignId   String
  campaignName String
  searchTerm   String
  impressions  Int      @default(0)
  clicks       Int      @default(0)
  cost         Float    @default(0)
  conversions  Int      @default(0)
  ctr          Float    @default(0)
  cpa          Float    @default(0)
  isExcluded   Boolean  @default(false)

  campaign Campaign @relation(fields: [campaignId], references: [id])
}

// データ同期ログ
model SyncLog {
  id         String    @id @default(cuid())
  platform   String    // "google" | "yahoo" | "bing" | "all"
  syncType   String    // "auto" | "manual"
  status     String    // "running" | "success" | "failed"
  message    String?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
}
