{
  "mcpServers": {
    "shadcn": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "shadcn@latest",
        "mcp"
      ],
      "env": {}
    },
    "heroui-react": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@heroui/react-mcp@latest"
      ],
      "env": {}
    }
  }
}